
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================== AUTH ======================
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  fullName  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ====================== HOUSES ======================
model House {
  id           String      @id @default(uuid())
  houseNumber  String      @unique   // ← Added unique constraint
  block        String?
  floor        Int
  site         String
  bedroom      Int?
  area         String
  status       HouseStatus @default(NONE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  lotteryResults LotteryResult[]

  @@map("houses")
  @@index([site, area, bedroom])
}

// ====================== APPLICANTS ======================
model Applicant {
  id          String            @id @default(uuid())
  idCode      String?           @unique
  username    String
  site        String            // Fully dynamic
  area        String
  bedroom     Int               @default(0)
  status      ApplicantStatus   @default(NONE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  lotteryResults LotteryResult[]

  @@map("applicants")
  @@index([site, area, bedroom])
}

// ====================== LOTTERY ======================
model LotteryResult {
  id           String   @id @default(uuid())
  lotteryRunId String
  username     String
  site         String
  area         String
  bedroom      Int
  floor        Int?
  houseNumber  String?
  status       String   // "WINNER" or "WAITLIST"
  drawDate     DateTime @default(now())

  houseId      String?
  house        House?   @relation(fields: [houseId], references: [id])
  applicantId  String
  applicant    Applicant @relation(fields: [applicantId], references: [id])

  @@map("lottery_results")
}

enum Role {
  ADMIN
  USER
}

enum HouseStatus {
  NONE
  PROVIDED
}

enum ApplicantStatus {
  NONE
  WINNER
  WAITLIST
}