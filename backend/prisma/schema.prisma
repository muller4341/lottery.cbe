
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String    @unique
  password        String
  fullName        String
  role            Role      @default(ADMIN)
  
  // New verification parameters fields
  resetToken      String?   @unique
  resetTokenExpiry DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("users")
}

// ====================== HOUSES ======================
model House {
  id           String      @id @default(uuid())
  houseNumber  String      @unique   // ← Added unique constraint
  block        String?
  floor        Int
  site         String
  subcity      String
  bedroom      Int?
  netarea       String
  proportionalarea       String
  commonarea       String
  totalarea       String
  area         String

  status       HouseStatus @default(NONE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  lotteryResults LotteryResult[]

  @@map("houses")
  @@index([site, area, bedroom])
}

// ====================== APPLICANTS ======================
model Applicant {
  id          String            @id @default(uuid())
  idCode      String?           @unique
  username    String
  site        String            // Fully dynamic
  area        String
  bedroom     Int               @default(0)
  status      ApplicantStatus   @default(NONE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  lotteryResults LotteryResult[]

  @@map("applicants")
  @@index([site, area, bedroom])
}

// ====================== LOTTERY ======================
model LotteryResult {
  id               String   @id @default(uuid())
  lotteryRunId     String
  username         String
  site             String
  subcity          String?  // ← Added field
  area             String
  bedroom          Int
  floor            Int?
  block            String?  // ← Added field
  houseNumber      String?
  
  // New granular area parameters matching modified house specifications
  netarea          String?  // ← Added field
  proportionalarea String?  // ← Added field
  commonarea       String?  // ← Added field
  totalarea        String?  // ← Added field

  status           String   // "WINNER" or "WAITLIST"
  drawDate         DateTime @default(now())

  houseId          String?
  house            House?   @relation(fields: [houseId], references: [id])
  applicantId      String
  applicant        Applicant @relation(fields: [applicantId], references: [id])

  @@map("lottery_results")
}
enum Role {
  ADMIN
  USER
}

enum HouseStatus {
  NONE
  PROVIDED
}

enum ApplicantStatus {
  NONE
  WINNER
  WAITLIST
}